{
    "ros": {
        "domain_id": 77,
        "cmd_vel_topic": "/cmd_vel",
        "scan_topic": "/scan",
        "image_topic": "/oakd/rgb/preview/image_raw",
        "use_twist_stamped": true
    },
    "robot": {
        "max_linear": 1.0,
        "max_angular": 3.0,
        "lidar_resolution": 360,
        "lidar_max_range": 12.0
    },
    "vision": {
        "backend": "auto",
        "yolo_model_path": "../yolonano/best.pt",
        "confidence_threshold": 0.85,
        "camera_fov_deg": 60.0,
        "async_vision": true,
        "detection_max_age": 1.0,
        "vpu": {
            "blob_path": "../yolonano/vpu/best.blob",
            "config_path": "../yolonano/vpu/best.json",
            "fps": 15.0,
            "camera_fov_deg": 42.0,
            "distance_scale": 1.0
        }
    }
}
